{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agenticflow/setupref/scenarios.schema.json",
  "title": "Feature Scenarios",
  "description": "Public scenario coverage plus holdout-suite pointers. Public scenarios are visible implementation guidance. Holdout suites should be pointers only; implementation agents should not read hidden holdout contents before verification.",
  "type": "object",
  "required": ["feature_id", "scenarios", "holdout_suites"],
  "properties": {
    "feature_id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "kind", "mode", "description", "linked_requirements"],
        "properties": {
          "id": { "type": "string", "pattern": "^SCN-[0-9]{3}$" },
          "title": { "type": "string" },
          "kind": {
            "enum": ["happy_path", "edge_case", "negative", "regression", "security", "data", "accessibility", "visual"]
          },
          "mode": {
            "enum": ["public", "holdout"],
            "description": "Use public for implementation-visible scenarios. Holdout scenarios should usually omit detailed steps and point to a holdout suite instead."
          },
          "description": { "type": "string" },
          "preconditions": { "type": "array", "items": { "type": "string" } },
          "steps": { "type": "array", "items": { "type": "string" } },
          "expected": { "type": "array", "items": { "type": "string" } },
          "linked_requirements": { "type": "array", "items": { "type": "string", "pattern": "^(REQ|AC)-[0-9]{3}$" } },
          "evidence_required": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "holdout_suites": {
      "type": "array",
      "description": "Pointers to hidden or late-loaded verification suites. Keep full contents outside the implementation context.",
      "items": {
        "type": "object",
        "required": ["id", "owner", "path", "runCommand"],
        "properties": {
          "id": { "type": "string", "pattern": "^HOLDOUT-[0-9]{3}$" },
          "owner": { "type": "string" },
          "path": { "type": "string", "description": "Repo-relative pointer, preferably under .spec/holdouts/<feature-id>/." },
          "runCommand": { "type": "string", "description": "Command that runs this suite without exposing contents in the prompt." },
          "description": { "type": "string" }
        }
      }
    }
  }
}

