{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agenticflow/setupref/layers/frontend.schema.json",
  "title": "Frontend Layer",
  "description": "The frontend layer of a feature: routes, pages, components, registry entry, role-gating (e.g. frontend/src/modules/<ctx> + a route registry).",
  "allOf": [{ "$ref": "./_layer.base.schema.json" }],
  "type": "object",
  "required": ["module", "routes"],
  "properties": {
    "module": {
      "type": "string",
      "description": "Module path, e.g. 'frontend/src/modules/sales'."
    },
    "registry_entry": {
      "type": "string",
      "description": "Registry/nav identifier this feature registers under, if any."
    },
    "routes": {
      "type": "array",
      "description": "User-facing routes this feature adds.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "page"],
        "properties": {
          "path": { "type": "string", "pattern": "^/" },
          "page": { "type": "string", "description": "Page component name, e.g. 'AccountsPage'." },
          "role_gated": { "type": "boolean" }
        }
      }
    },
    "components": {
      "type": "array",
      "description": "Notable components introduced.",
      "items": { "type": "string" }
    },
    "design_tokens": {
      "type": "boolean",
      "description": "True if the feature must adhere to the shared design-token system."
    }
  }
}
