{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agenticflow/setupref/layers/backend.schema.json",
  "title": "Backend Layer",
  "description": "The backend layer of a feature. A DDD context layout — domain/repository/service + routes (e.g. backend/src/contexts/<ctx>/...).",
  "allOf": [{ "$ref": "./_layer.base.schema.json" }],
  "type": "object",
  "required": ["context", "endpoints"],
  "properties": {
    "context": {
      "type": "string",
      "description": "Bounded-context path, e.g. 'backend/src/contexts/sales'."
    },
    "domain": {
      "type": "array",
      "description": "Pure domain objects (no DB/HTTP) + their invariants.",
      "items": { "type": "string" }
    },
    "repository": {
      "type": "object",
      "description": "Port + adapter for persistence.",
      "properties": {
        "port": { "type": "string", "description": "Interface module, e.g. 'sales-repository.ts'." },
        "adapter": { "type": "string", "description": "Implementation, e.g. 'sales-repository.impl.ts'." }
      }
    },
    "services": {
      "type": "array",
      "description": "Service methods orchestrating domain + repository.",
      "items": { "type": "string" }
    },
    "endpoints": {
      "type": "array",
      "description": "HTTP endpoints this feature exposes.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["method", "path"],
        "properties": {
          "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
          "path": { "type": "string", "pattern": "^/" },
          "request": { "type": "string", "description": "Request DTO type name." },
          "response": { "type": "string", "description": "Response type name." }
        }
      }
    },
    "authz": {
      "type": "array",
      "description": "Authorization rules / required roles per endpoint or feature.",
      "items": { "type": "string" }
    },
    "error_contracts": {
      "type": "array",
      "description": "Named error responses the feature can return.",
      "items": { "type": "string" }
    },
    "audit_events": {
      "type": "array",
      "description": "Audit/activity events emitted.",
      "items": { "type": "string" }
    }
  }
}
