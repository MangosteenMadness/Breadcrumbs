# Environment variables
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# ...except spec evidence. Evidence is pointer-based: these logs ARE the proof that a
# requirement is met, so they must be committed despite the *.log rule above.
!.spec/evidence/**/*.log

# Local backups taken before a schema migration
ingestion/*.db.bak

# Dependencies
node_modules/

# Cairn: never commit the live authenticated session (a real login credential)
ingestion/.secrets/
ingestion/*.db-shm
ingestion/*.db-wal

# Cairn ingestion output (cairn.db, transcripts/) IS tracked intentionally so the
# team can collaborate on the shared graph store without each re-scraping K Pro.

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
dist/
build/
*.egg-info/
.breadcrumbs/

# GitKB: store/ is the canonical, shareable KB data - tracked intentionally so the
# team gets it via `git pull` without each running `git-kb init`. Only the derived,
# regeneratable local index cache and per-user checkout workspace are ignored.
.kb/.cache/
.kb/workspace/
.kb/workspaces/
