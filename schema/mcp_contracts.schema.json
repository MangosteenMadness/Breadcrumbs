            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Live Context"
        },
        "live_session_title": {
          "anyOf": [
            {
              "maxLength": 240,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Live Session Title"
        },
        "proposition": {
          "minLength": 1,
          "title": "Proposition",
          "type": "string"
        },
        "rationale": {
          "minLength": 1,
          "title": "Rationale",
          "type": "string"
        },
        "replicates": {
          "default": 5,
          "maximum": 20,
          "minimum": 3,
          "title": "Replicates",
          "type": "integer"
        },
        "scope": {
          "additionalProperties": true,
          "title": "Scope",
          "type": "object"
        },
        "source_session_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
