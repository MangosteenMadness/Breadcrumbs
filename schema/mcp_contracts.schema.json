          "default": null,
          "title": "Markdown"
        },
        "matches": {
          "items": {
            "$ref": "#/$defs/Match"
          },
          "title": "Matches",
          "type": "array"
        },
        "searched": {
          "minimum": 0,
          "title": "Searched",
          "type": "integer"
        },
        "verdict": {
          "enum": [
            "match",
            "open"
          ],
          "title": "Verdict",
          "type": "string"
        }
      },
      "required": [
        "verdict",
        "matches",
        "searched"
      ],
      "title": "DuplicationResult",
      "type": "object"
    },
