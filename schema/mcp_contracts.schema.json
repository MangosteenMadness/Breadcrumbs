        "quote_start": {
          "minimum": 0,
          "title": "Quote Start",
          "type": "integer"
        },
        "rank": {
          "minimum": 1,
          "title": "Rank",
          "type": "integer"
        },
        "relevance_score": {
          "minimum": 0,
          "title": "Relevance Score",
          "type": "number"
        },
        "role": {
          "enum": [
            "user",
            "assistant"
          ],
          "title": "Role",
          "type": "string"
        },
        "session_title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Session Title"
        },
        "source_message_hash": {
          "title": "Source Message Hash",
          "type": "string"
        },
        "source_message_id": {
          "title": "Source Message Id",
          "type": "string"
        },
        "source_researcher": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Researcher"
        },
        "source_session_id": {
          "title": "Source Session Id",
          "type": "string"
        }
      },
      "required": [
        "rank",
        "source_message_id",
        "source_session_id",
        "source_message_hash",
        "message_seq",
        "role",
        "evidence_quote",
        "quote_start",
        "quote_end",
        "relevance_score"
      ],
      "title": "EvidenceCandidate",
      "type": "object"
    },
    "FindingRelationship": {
      "additionalProperties": false,
      "properties": {
        "finding_id": {
          "title": "Finding Id",
          "type": "string"
        },
        "relationship": {
          "enum": [
            "duplicate_of",
            "extends",
            "related",
            "contradicts"
          ],
          "title": "Relationship",
          "type": "string"
        }
      },
      "required": [
        "finding_id",
        "relationship"
      ],
      "title": "FindingRelationship",
      "type": "object"
