            "decision",
            "constraint",
            "exception",
            "abandoned",
            "belief_revision"
          ],
          "title": "Kind",
          "type": "string"
        },
        "live_context": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/LiveInteractionTurn"
              },
              "maxItems": 12,
              "minItems": 1,
              "type": "array"
