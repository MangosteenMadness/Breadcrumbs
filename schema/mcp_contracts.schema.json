        "instruction": {
          "title": "Instruction",
          "type": "string"
        },
        "phase": {
          "enum": [
            "prior",
            "posterior"
          ],
          "title": "Phase",
          "type": "string"
        },
        "proposition": {
          "title": "Proposition",
          "type": "string"
        }
      },
      "required": [
        "phase",
        "proposition",
        "context",
        "context_truncated",
        "instruction",
        "allowed_labels"
      ],
      "title": "ElicitationPacket",
      "type": "object"
    },
    "ElicitationProtocol": {
      "additionalProperties": false,
      "properties": {
        "model": {
          "title": "Model",
          "type": "string"
        },
        "posterior": {
          "$ref": "#/$defs/ElicitationPacket"
        },
        "prior": {
          "$ref": "#/$defs/ElicitationPacket"
        },
        "replicates": {
          "maximum": 20,
          "minimum": 3,
          "title": "Replicates",
          "type": "integer"
        },
        "run_id": {
          "title": "Run Id",
          "type": "string"
        },
        "scoring_method": {
          "const": "beta_fractional_jsd_v1",
          "title": "Scoring Method",
          "type": "string"
        }
      },
      "required": [
        "model",
        "run_id",
        "replicates",
        "scoring_method",
        "prior",
        "posterior"
      ],
      "title": "ElicitationProtocol",
      "type": "object"
    },
    "EvidenceCandidate": {
      "additionalProperties": false,
      "properties": {
        "evidence_quote": {
          "title": "Evidence Quote",
          "type": "string"
        },
        "message_seq": {
          "title": "Message Seq",
          "type": "integer"
        },
        "quote_end": {
          "minimum": 1,
          "title": "Quote End",
          "type": "integer"
