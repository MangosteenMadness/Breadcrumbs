    "CheckDuplicationInput": {
      "additionalProperties": false,
      "properties": {
        "hypothesis_text": {
          "minLength": 1,
          "title": "Hypothesis Text",
          "type": "string"
        },
        "limit": {
          "default": 5,
          "maximum": 20,
          "minimum": 1,
          "title": "Limit",
          "type": "integer"
        }
      },
      "required": [
        "hypothesis_text"
      ],
      "title": "CheckDuplicationInput",
      "type": "object"
    },
    "DuplicationResult": {
      "additionalProperties": false,
      "properties": {
        "markdown": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
