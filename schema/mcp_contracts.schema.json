      "type": "object"
    },
    "Match": {
      "additionalProperties": false,
      "properties": {
        "author": {
          "title": "Author",
          "type": "string"
        },
        "disease": {
          "title": "Disease",
          "type": "string"
        },
        "effect": {
          "title": "Effect",
          "type": "string"
        },
        "hypothesis_text": {
          "title": "Hypothesis Text",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
