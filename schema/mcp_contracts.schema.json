{
  "$defs": {
    "CheckDuplicationInput": {
      "additionalProperties": false,
      "properties": {
        "hypothesis_text": {
          "minLength": 1,
          "title": "Hypothesis Text",
          "type": "string"
        },
        "limit": {
          "default": 5,
          "maximum": 20,
          "minimum": 1,
          "title": "Limit",
          "type": "integer"
        }
      },
      "required": [
        "hypothesis_text"
      ],
      "title": "CheckDuplicationInput",
      "type": "object"
    },
    "DuplicationResult": {
      "additionalProperties": false,
      "properties": {
        "markdown": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Markdown"
        },
        "matches": {
          "items": {
            "$ref": "#/$defs/Match"
          },
          "title": "Matches",
          "type": "array"
        },
        "searched": {
          "minimum": 0,
          "title": "Searched",
          "type": "integer"
        },
        "verdict": {
          "enum": [
            "match",
            "open"
          ],
          "title": "Verdict",
          "type": "string"
        }
      },
      "required": [
        "verdict",
        "matches",
        "searched"
      ],
      "title": "DuplicationResult",
      "type": "object"
    },
    "ElicitationPacket": {
      "additionalProperties": false,
      "properties": {
        "allowed_labels": {
          "items": {
            "enum": [
              "strongly_disbelieve",
              "disbelieve",
              "uncertain",
              "believe",
              "strongly_believe"
            ],
            "type": "string"
          },
          "title": "Allowed Labels",
          "type": "array"
        },
        "context": {
          "title": "Context",
          "type": "string"
        },
        "context_truncated": {
          "title": "Context Truncated",
          "type": "boolean"
