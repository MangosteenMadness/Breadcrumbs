          { "name": "table_name", "type": "text" },
          { "name": "column_name", "type": "text" },
          { "name": "possible_values", "type": "text" },
          { "name": "data_type", "type": "text" },
          { "name": "completeness_pct", "type": "real" }
        ]
      }
    ],
    "migrations": ["BC-GRAPH-006 — CHECK-constraint table rebuild"],
    "erd_ref": "References/Breadcrumbs-v2.pdf (panel 3)"
  },
  "open_questions": [
    "Should `contradicts` be retained as a superset of the Breadcrumbs-v2 edge vocabulary? See review-queue.md row 1."
  ]
}
